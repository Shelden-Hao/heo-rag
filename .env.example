# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
LLM_MODEL=deepseek-chat

# 本地嵌入模型（免费，不需要 API Key）
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# 文档目录（导入时扫描此目录）
DOCUMENTS_DIR=./data/documents

# 数据库
DB_PATH=./data/rag.db

# 检索
RETRIEVAL_TOP_K=5
HYBRID_WEIGHT_VECTOR=0.5
HYBRID_WEIGHT_KEYWORD=0.5
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# HuggingFace 国内镜像（无法直连 HuggingFace 时使用）
HF_ENDPOINT=https://hf-mirror.com

# 服务
HOST=0.0.0.0
PORT=8000
